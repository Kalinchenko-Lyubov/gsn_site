<div id="imageModal" class="image-modal">
    <span class="close-modal" onclick="closeImage()">
        &times;
    </span>
    <span class="gallery-prev" onclick="prevImage()">❮</span>
    <img id="modalImage" class="modal-content">
    <span class="gallery-next" onclick="nextImage()">❯</span>
